                    },
                    "elements": [
                        {
                            "id": "df56c77",
                            "settings": {
                                "title": "About Drift",
                                "header_size": "h4",
                                "__globals__": {
                                    "title_color": ""
                                }
                            },
                            "widgetType": "heading",
                            "elType": "widget"
                        },
                        {
                            "id": "9b74d57",
                            "settings": {
                                "editor": "<p data-start=\"21\" data-end=\"326\">We are a modern digital design agency focused on creating high-quality user interfaces and product experiences for web, SaaS, and enterprise platforms. Our mission is to help businesses transform their ideas into visually compelling and highly functional digital products that deliver real value to users.<br \/>We specialize in UI design, product design, and interface systems, working with startups, growing companies, and established brands worldwide. Our team combines creativity, strategic thinking, and technical understanding to design interfaces that are not only beautiful but also intuitive, scalable, and ready for development.<\/p>",
                                "__globals__": {
                                    "text_color": ""
                                }
                            },
                            "widgetType": "text-editor",
                            "elType": "widget"
                        },
                        {
                            "id": "954e3fe",
                            "settings": {
                                "editor": "<p data-start=\"21\" data-end=\"326\">At our core, we believe great design is more than aesthetics—it is about solving problems, improving usability, and creating seamless user experiences. We follow modern design standards, maintain strong design systems, and collaborate closely with developers and product teams to ensure every design is practical and implementation-ready.<\/p>",
                                "__globals__": {
                                    "text_color": ""
                                }
                            },
                            "widgetType": "text-editor",
                            "elType": "widget"
                        },
                        {
                            "id": "12258c4",
                            "settings": {
                                "editor": "<p data-start=\"21\" data-end=\"326\">Our culture is built on innovation, attention to detail, and continuous improvement. We are passionate about design, committed to quality, and dedicated to helping our clients build world-class digital products.<\/p>",
                                "__globals__": {
                                    "text_color": ""
                                }
                            },
                            "widgetType": "text-editor",
                            "elType": "widget"
                        }
                    ],
