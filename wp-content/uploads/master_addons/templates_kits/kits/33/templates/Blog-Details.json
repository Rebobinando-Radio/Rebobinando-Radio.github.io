                        {
                            "id": "24aed23",
                            "settings": {
                                "title": "Choosing the Right Money Transfer Platform for Your Needs",
                                "header_size": "h1",
                                "align": "center"
                            },
                            "widgetType": "heading",
                            "elType": "widget"
                        },
                        {
                            "id": "8766d3e",
                            "settings": {
                                "image": {
                                    "url": "http://rebobinando.local/wp-content/uploads/master_addons/templates_kits/images/kit-33-Blog-Details-ee83143b032aa46f5f4ebd01d6ea6621.webp",
                                    "id": 379,
                                    "size": "",
                                    "alt": "",
                                    "source": "library"
                                },
                                "image_size": "full",
                                "image_border_radius": {
                                    "unit": "px",
