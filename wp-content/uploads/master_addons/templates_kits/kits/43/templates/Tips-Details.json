                    },
                    "elements": [
                        {
                            "id": "1cbe2b18",
                            "settings": {
                                "content_width": "full",
                                "flex_gap": {
                                    "column": "0",
                                    "row": "20",
                                    "isLinked": false,
                                    "unit": "px",
                                    "size": 0
