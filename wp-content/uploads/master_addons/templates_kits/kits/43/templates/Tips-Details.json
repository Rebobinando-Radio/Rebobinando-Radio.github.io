                                        "__globals__": {
                                            "text_color": "globals/colors?id=65246f0"
                                        }
                                    },
                                    "widgetType": "text-editor",
                                    "elType": "widget"
                                }
                            ],
                            "elType": "container",
                            "isInner": true
                        }
